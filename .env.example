# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# -------------------------------------------------------------------
# Aura license backend (Vercel + Firebase RTDB)
# -------------------------------------------------------------------
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
FIREBASE_DATABASE_URL=""
FIREBASE_WEB_API_KEY=""
FIRESTORE_DATABASE_ID=""

# PEM private key for /api/launcher/manifest signing (Ed25519)
# Keep as one line with \n in Vercel env vars.
MANIFEST_PRIVATE_KEY_PEM=""

# Optional static artifact info (if set, file hashing on server is skipped)
CLIENT_VERSION="1.21.4-20260329-hotfix6"
CLIENT_DOWNLOAD_URL="https://your-domain.com/downloads/Aura.jar"
CLIENT_SHA256="d35e1cfe507dadc96796574b2064266c57e2ea8edb46a8831090d79e48cc1ef1"
CLIENT_SIZE="100039584"
CLIENT_JAR_PATH="artifacts/Aura.jar"

# Session and rate limits
SESSION_TTL_MS="86400000"
MANIFEST_TTL_MS="60000"
DOWNLOAD_LINK_TTL_MS="300000"
FREE_HWID_RESETS_PER_WINDOW="1"
HWID_RESET_WINDOW_MS="2592000000"
LAUNCHER_LOGIN_RATE_LIMIT="12"
LAUNCHER_LOGIN_WINDOW_MS="600000"
LAUNCHER_VERIFY_RATE_LIMIT="120"
LAUNCHER_VERIFY_WINDOW_MS="600000"
LAUNCHER_MANIFEST_RATE_LIMIT="120"
LAUNCHER_MANIFEST_WINDOW_MS="600000"
PAYMENTS_CREATE_RATE_LIMIT="30"
PAYMENTS_CREATE_WINDOW_MS="600000"
SECURITY_EVENT_RATE_LIMIT="120"
SECURITY_EVENT_WINDOW_MS="600000"

# Payments
PAYMENT_WEBHOOK_SECRET=""
YOOKASSA_SHOP_ID="YOUR_SHOP_ID"
YOOKASSA_SECRET_KEY="YOUR_YOOKASSA_SECRET_KEY"
YOOKASSA_WEBHOOK_SECRET="YOUR_WEBHOOK_SECRET"
YOOKASSA_API_URL="https://api.yookassa.ru/v3"

# Download links and artifact storage
APP_URL="https://your-domain.com"
DOWNLOAD_LINK_SECRET="replace_with_long_random_secret_64_plus_chars"
CLIENT_ARTIFACT_PATH="artifacts/Aura.jar"
CLIENT_ARTIFACT_URL=""
CLIENT_ARTIFACT_NAME="Aura.jar"
CLIENT_ARTIFACT_CONTENT_TYPE="application/java-archive"
JRE_ARTIFACT_PATH="artifacts/jre.zip"
JRE_ARTIFACT_URL="https://github.com/Unpelsi/jre/releases/download/1.0/jre.zip"
JRE_ARTIFACT_NAME="jre.zip"
JRE_ARTIFACT_CONTENT_TYPE="application/zip"
JRE_VERSION="17.0.18+8"
ASSETS_ARTIFACT_PATH="artifacts/MinecraftAssets.zip"
ASSETS_ARTIFACT_URL="https://github.com/Unpelsi/minecraft/releases/download/1.0/MinecraftAssets.zip"
ASSETS_ARTIFACT_NAME="MinecraftAssets.zip"
ASSETS_ARTIFACT_CONTENT_TYPE="application/zip"
ASSETS_VERSION="1.0.0"
LAUNCHER_ARTIFACT_PATH="artifacts/AuraLauncher.exe"
LAUNCHER_ARTIFACT_URL=""
LAUNCHER_ARTIFACT_NAME="AuraLauncher.exe"
LAUNCHER_ARTIFACT_CONTENT_TYPE="application/vnd.microsoft.portable-executable"
LAUNCHER_VERSION="mega-webview-x64-20260329-hotfix-javaw"
LAUNCHER_SHA256="bc8f44c3943c76a204d307c50799a762082558d2e63bbefb93592db7867ecbc6"
LAUNCHER_SIZE="536064"

# Manifest key rotation (optional key-ring)
MANIFEST_CURRENT_KID="v1"
MANIFEST_PRIVATE_KEYS_JSON="{\"current\":\"v1\",\"keys\":{\"v1\":\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\"}}"

# Admin API
ADMIN_API_SECRET=""
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
SUBSCRIPTION_KEY_PEPPER="replace_with_long_random_secret_64_plus_chars"
SUBSCRIPTION_KEY_REDEEM_RATE_LIMIT="10"
SUBSCRIPTION_KEY_REDEEM_WINDOW_MS="600000"
ADMIN_KEY_CREATE_RATE_LIMIT="60"
ADMIN_KEY_CREATE_WINDOW_MS="600000"

# Frontend Vite Firebase envs
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_DATABASE_URL=""
VITE_LAUNCHER_DOWNLOAD_URL="https://fade-visuals.vercel.app/downloads/AuraLauncher.exe"
VITE_LAUNCHER_VERSION="mega-webview-x64-20260329-hotfix-javaw"
VITE_LAUNCHER_SHA256="bc8f44c3943c76a204d307c50799a762082558d2e63bbefb93592db7867ecbc6"
VITE_LAUNCHER_LINK_TTL_MS="300000"





